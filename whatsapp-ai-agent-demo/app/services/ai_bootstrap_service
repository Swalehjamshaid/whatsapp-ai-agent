@dataclass
class ResourceHealth:
    """Health status of a resource"""
    name: str
    available: bool
    load_time_ms: float = 0.0
    error: Optional[str] = None
    metadata: Dict[str, Any] = field(default_factory=dict)


class AIBootstrapService:
    """
    Initialize expensive optional resources once and reuse them safely.
    Supports conversation state, semantic search, NLP, and AI resources.
    """

    _instance: Optional["AIBootstrapService"] = None
    _instance_lock = threading.Lock()
    
    # Resource timeout in seconds
    RESOURCE_TIMEOUT = 30
    MAX_RETRIES = 3
    RETRY_DELAY = 1.0

    def __new__(cls) -> "AIBootstrapService":
        if cls._instance is None:
            with cls._instance_lock:
                if cls._instance is None:
                    cls._instance = super().__new__(cls)
                    cls._instance._initialized = False
        return cls._instance

    def __init__(self) -> None:
        if self._initialized:
            return
        with self._instance_lock:
            if self._initialized:
                return
            self._lock = threading.RLock()
            self._resources: dict[str, Any] = {}
            self._errors: dict[str, str] = {}
            self._load_times: dict[str, float] = {}
            self._resource_health: dict[str, ResourceHealth] = {}
            self._executor = ThreadPoolExecutor(
                max_workers=os.cpu_count() or 4,
                thread_name_prefix="ai-bootstrap"
            )
            self._resource_retries: dict[str, int] = {}
            self._initialized = True
            self._warmup_complete = False
            self._warmup_start_time: Optional[float] = None
            self._warmup_end_time: Optional[float] = None
            
            # Track registered resources
            self._registered_factories: dict[str, Callable[[], Any]] = {}
            self._register_resources()
            
            logger.info("✅ AIBootstrapService initialized")

    def _register_resources(self) -> None:
        """Register all available resources"""
        self._registered_factories = {
            "embeddings": self._create_embeddings,
            "spacy": self._create_spacy,
            "flashrank": self._create_flashrank,
            "sqlglot": self._create_sqlglot,
            "groq": self._create_groq,
            "openai": self._create_openai,
            "anthropic": self._create_anthropic,
            "instructor": self._create_instructor,
            "nltk": self._create_nltk,
            "textblob": self._create_textblob,
            "symspell": self._create_symspell,
            "dateparser": self._create_dateparser,
            "lingua": self._create_lingua,
            "ahocorasick": self._create_ahocorasick,
            "semantic_router": self._create_semantic_router,
            "joblib": self._create_joblib,
            "regex": self._create_regex,
            "ftfy": self._create_ftfy,
            "unidecode": self._create_unidecode,
            "expiringdict": self._create_expiringdict,
            "jsonschema": self._create_jsonschema,
            "aiofiles": self._create_aiofiles,
        }

    # ============================================================
    # RESOURCE CREATION METHODS WITH RETRY
    # ============================================================

    def _create_with_retry(self, key: str, factory: Callable[[], T]) -> Optional[T]:
        """Create resource with retry logic"""
        retry_count = self._resource_retries.get(key, 0)
        
        for attempt in range(self.MAX_RETRIES):
            try:
                start_time = time.perf_counter()
                value = factory()
                load_time = (time.perf_counter() - start_time) * 1000
                
                self._load_times[key] = load_time
                self._resource_health[key] = ResourceHealth(
                    name=key,
                    available=True,
                    load_time_ms=load_time,
                    metadata={"attempt": attempt + 1, "retries": retry_count}
                )
                
                if attempt > 0:
                    logger.info(f"✅ Resource {key} loaded after {attempt + 1} attempts ({load_time:.2f}ms)")
                else:
                    logger.info(f"✅ Resource {key} loaded ({load_time:.2f}ms)")
                
                self._resource_retries[key] = 0  # Reset retries on success
                return value
                
            except Exception as error:
                retry_count += 1
                self._resource_retries[key] = retry_count
                error_msg = str(error)
                
                if attempt < self.MAX_RETRIES - 1:
                    wait_time = self.RETRY_DELAY * (2 ** attempt)  # Exponential backoff
                    logger.warning(f"⚠️ Resource {key} attempt {attempt + 1} failed: {error_msg}. Retrying in {wait_time:.1f}s...")
                    time.sleep(wait_time)
                else:
                    self._errors[key] = error_msg
                    self._resource_health[key] = ResourceHealth(
                        name=key,
                        available=False,
                        error=error_msg,
                        metadata={"attempts": attempt + 1}
                    )
                    logger.warning(f"❌ Resource {key} unavailable after {self.MAX_RETRIES} attempts: {error_msg}")
                    return None
        
        return None

    def _once(self, key: str, factory: Callable[[], T]) -> Optional[T]:
        """Get or create resource with timeout support"""
        existing = self._resources.get(key)
        if existing is not None:
            return existing
        
        if key in self._errors:
            return None
        
        with self._lock:
            existing = self._resources.get(key)
            if existing is not None:
                return existing
            
            # Use retry mechanism
            value = self._create_with_retry(key, factory)
            if value is not None:
                self._resources[key] = value
            return value

