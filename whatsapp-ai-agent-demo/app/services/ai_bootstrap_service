    # ============================================================
    # WARMUP & HEALTH
    # ============================================================

    def warmup(self, include_ai_providers: bool = False, include_heavy_models: bool = False) -> None:
        """
        Schedule optional startup warm-up without blocking FastAPI startup.
        
        Args:
            include_ai_providers: Include AI provider clients (Groq, OpenAI, Anthropic)
            include_heavy_models: Include heavy models (spacy, sentence-transformers)
        """
        self._warmup_start_time = time.perf_counter()
        
        factories = []
        
        # Always include lightweight resources
        factories.extend([
            self.get_regex,
            self.get_ftfy,
            self.get_unidecode,
            self.get_dateparser,
            self.get_expiringdict,
            self.get_jsonschema,
            self.get_aiofiles,
            self.get_ahocorasick,
        ])
        
        if include_heavy_models:
            factories.extend([
                self.get_embeddings,
                self.get_spacy,
                self.get_nltk,
                self.get_textblob,
                self.get_semantic_router,
            ])
        
        if include_ai_providers:
            factories.extend([
                self.get_groq,
                self.get_openai,
                self.get_anthropic,
                self.get_instructor,
            ])
        
        for factory in factories:
            self._executor.submit(factory)
        
        self._warmup_complete = True
        self._warmup_end_time = time.perf_counter()
        
        logger.info(f"🚀 Warmup started for {len(factories)} resources")

    async def warmup_async(self, include_ai_providers: bool = False, include_heavy_models: bool = False) -> None:
        """Async warmup method for FastAPI startup"""
        self._warmup_start_time = time.perf_counter()
        
        resources = []
        
        # Lightweight resources
        resources.extend([
            self.get_regex,
            self.get_ftfy,
            self.get_unidecode,
            self.get_dateparser,
            self.get_expiringdict,
            self.get_jsonschema,
            self.get_aiofiles,
            self.get_ahocorasick,
        ])
        
        if include_heavy_models:
            resources.extend([
                self.get_embeddings,
                self.get_spacy,
                self.get_nltk,
                self.get_textblob,
                self.get_semantic_router,
            ])
        
        if include_ai_providers:
            resources.extend([
                self.get_groq,
                self.get_openai,
                self.get_anthropic,
                self.get_instructor,
            ])
        
        # Submit all to executor
        loop = asyncio.get_event_loop()
        futures = []
        for resource in resources:
            futures.append(loop.run_in_executor(self._executor, resource))
        
        # Wait for all to complete or timeout
        try:
            await asyncio.wait_for(asyncio.gather(*futures, return_exceptions=True), timeout=30.0)
        except asyncio.TimeoutError:
            logger.warning("⚠️ Warmup timed out after 30 seconds")
        
        self._warmup_complete = True
        self._warmup_end_time = time.perf_counter()
        
        warmup_duration = (self._warmup_end_time - self._warmup_start_time) * 1000
        logger.info(f"✅ Warmup completed in {warmup_duration:.2f}ms")

    def health(self) -> dict[str, Any]:
        """Get health status of all resources"""
        return {
            "initialized": sorted(self._resources.keys()),
            "available_count": len(self._resources),
            "errors": dict(self._errors),
            "error_count": len(self._errors),
            "load_times": dict(self._load_times),
            "resource_health": {
                name: {
                    "available": health.available,
                    "load_time_ms": health.load_time_ms,
                    "error": health.error,
                }
                for name, health in self._resource_health.items()
            },
            "ready": self._initialized,
            "warmup_complete": self._warmup_complete,
            "warmup_duration_ms": (
                (self._warmup_end_time - self._warmup_start_time) * 1000
                if self._warmup_start_time and self._warmup_end_time
                else 0
            ),
        }

    def get_resource_status(self, resource_name: str) -> Optional[ResourceHealth]:
        """Get status of a specific resource"""
        return self._resource_health.get(resource_name)

    def is_available(self, resource_name: str) -> bool:
        """Check if a resource is available"""
        health = self._resource_health.get(resource_name)
        if health:
            return health.available
        return resource_name in self._resources

    def clear_resource(self, resource_name: str) -> None:
        """Clear a resource from cache (for testing)"""
        with self._lock:
            if resource_name in self._resources:
                del self._resources[resource_name]
            if resource_name in self._errors:
                del self._errors[resource_name]
            if resource_name in self._resource_health:
                del self._resource_health[resource_name]
            logger.info(f"🔄 Cleared resource: {resource_name}")

    def clear_all(self) -> None:
        """Clear all resources (for testing)"""
        with self._lock:
            self._resources.clear()
            self._errors.clear()
            self._load_times.clear()
            self._resource_health.clear()
            self._resource_retries.clear()
            logger.info("🔄 Cleared all resources")


