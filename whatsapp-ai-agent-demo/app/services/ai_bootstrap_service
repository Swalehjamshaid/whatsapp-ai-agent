    def get_embeddings(self) -> Any:
        """Get sentence-transformers embeddings - CACHED forever after first load"""
        def factory() -> Any:
            try:
                from sentence_transformers import SentenceTransformer
                model_name = os.getenv("SENTENCE_TRANSFORMER_MODEL", "all-MiniLM-L6-v2")
                device = os.getenv("EMBEDDING_DEVICE", "cpu")
                logger.info(f"📥 Loading embedding model: {model_name} (this happens ONCE at startup)")
                return SentenceTransformer(model_name, device=device)
            except ImportError:
                logger.warning("⚠️ sentence-transformers not installed")
                return None
        return self._once("embeddings", factory)

