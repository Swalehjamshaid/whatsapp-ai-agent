"""
Process-wide, lazy AI resource bootstrap for analytics services.

CRITICAL FIX: Models are loaded ONCE at startup and CACHED forever.
No model loading happens during user queries after warmup.
"""

from __future__ import annotations

import logging
import os
import threading
import time
from concurrent.futures import ThreadPoolExecutor
from dataclasses import dataclass, field
from typing import Any, Callable, Optional, TypeVar, Dict, List

logger = logging.getLogger(__name__)
T = TypeVar("T")


@dataclass
class ResourceHealth:
    """Health status of a resource"""
    name: str
    available: bool
    load_time_ms: float = 0.0
    error: Optional[str] = None
    metadata: Dict[str, Any] = field(default_factory=dict)


class AIBootstrapService:
    """
    Initialize expensive optional resources once and reuse them safely.
    
    CRITICAL: All resources are loaded ONCE and CACHED.
    No resource loading happens during user queries after warmup.
    """

    _instance: Optional["AIBootstrapService"] = None
    _instance_lock = threading.Lock()
    
    MAX_RETRIES = 2
    RETRY_DELAY = 0.5

    def __new__(cls) -> "AIBootstrapService":
        if cls._instance is None:
            with cls._instance_lock:
                if cls._instance is None:
                    cls._instance = super().__new__(cls)
                    cls._instance._initialized = False
        return cls._instance

    def __init__(self) -> None:
        if self._initialized:
            return
        with self._instance_lock:
            if self._initialized:
                return
            self._lock = threading.RLock()
            self._resources: dict[str, Any] = {}
            self._errors: dict[str, str] = {}
            self._load_times: dict[str, float] = {}
            self._resource_health: dict[str, ResourceHealth] = {}
            self._executor = ThreadPoolExecutor(
                max_workers=os.cpu_count() or 4,
                thread_name_prefix="ai-bootstrap"
            )
            self._initialized = True
            self._warmed_up = False
            self._warmup_start_time: Optional[float] = None
            self._warmup_end_time: Optional[float] = None
            logger.info("✅ AIBootstrapService initialized")

    def _once(self, key: str, factory: Callable[[], T]) -> Optional[T]:
        """
        Get or create resource - CACHED after first load.
        CRITICAL: Resources are loaded ONCE and reused forever.
        """
        
        # CRITICAL FIX: Check cache FIRST - no reloading
        if key in self._resources:
            logger.debug(f"✅ Resource {key} returned from cache (cached)")
            return self._resources[key]
        
        if key in self._errors:
            logger.debug(f"⏭️ Resource {key} previously failed, skipping")
            return None
        
        with self._lock:
            # Double-check after acquiring lock
            if key in self._resources:
                return self._resources[key]
            
            if key in self._errors:
                return None
            
            logger.info(f"🔄 Loading resource {key} for first time (will be cached forever)")
            start_time = time.perf_counter()
            
            # Try with retry
            for attempt in range(self.MAX_RETRIES):
                try:
                    value = factory()
                    if value is not None:
                        load_time = (time.perf_counter() - start_time) * 1000
                        self._resources[key] = value
                        self._load_times[key] = load_time
                        self._resource_health[key] = ResourceHealth(
                            name=key,
                            available=True,
                            load_time_ms=load_time,
                            metadata={"attempt": attempt + 1}
                        )
                        logger.info(f"✅ Resource {key} loaded and cached forever ({load_time:.2f}ms)")
                        return value
                except Exception as error:
                    if attempt < self.MAX_RETRIES - 1:
                        wait_time = self.RETRY_DELAY * (2 ** attempt)
                        logger.warning(f"⚠️ Resource {key} attempt {attempt + 1} failed. Retrying in {wait_time:.1f}s...")
                        time.sleep(wait_time)
                    else:
                        self._errors[key] = str(error)
                        self._resource_health[key] = ResourceHealth(
                            name=key,
                            available=False,
                            error=str(error)
                        )
                        logger.warning(f"❌ Resource {key} unavailable after {self.MAX_RETRIES} attempts: {error}")
                        return None
            
            return None

