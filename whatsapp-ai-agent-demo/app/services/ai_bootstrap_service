    def _create_embeddings(self) -> Any:
        """Create sentence transformer embeddings"""
        try:
            from sentence_transformers import SentenceTransformer
            model_name = os.getenv("SENTENCE_TRANSFORMER_MODEL", "all-MiniLM-L6-v2")
            device = os.getenv("EMBEDDING_DEVICE", "cpu")
            return SentenceTransformer(model_name, device=device)
        except ImportError as e:
            logger.warning(f"⚠️ sentence-transformers not installed: {e}")
            raise

    def _create_spacy(self) -> Any:
        """Create spacy NLP model"""
        try:
            import spacy
            model_name = os.getenv("SPACY_MODEL", "en_core_web_sm")
            try:
                return spacy.load(model_name)
            except OSError:
                # Download and load if not available
                import subprocess
                logger.info(f"📥 Downloading spacy model: {model_name}")
                subprocess.run(["python", "-m", "spacy", "download", model_name], check=True)
                return spacy.load(model_name)
            except Exception:
                # Fallback to blank model
                logger.warning(f"⚠️ Using blank spacy model as fallback")
                return spacy.blank("en")
        except ImportError as e:
            logger.warning(f"⚠️ spacy not installed: {e}")
            raise

    def _create_flashrank(self) -> Any:
        """Create flashrank ranker"""
        try:
            from flashrank import Ranker
            model_name = os.getenv("FLASHRANK_MODEL", "ms-marco-TinyBERT-L-2-v2")
            return Ranker(model_name=model_name)
        except ImportError as e:
            logger.warning(f"⚠️ flashrank not installed: {e}")
            raise

    def _create_nltk(self) -> Any:
        """Create nltk resources"""
        try:
            import nltk
            # Download required data
            resources = ['punkt', 'stopwords', 'averaged_perceptron_tagger', 'wordnet']
            for resource in resources:
                try:
                    nltk.data.find(f'tokenizers/{resource}')
                except LookupError:
                    nltk.download(resource, quiet=True)
            return nltk
        except ImportError as e:
            logger.warning(f"⚠️ nltk not installed: {e}")
            raise

