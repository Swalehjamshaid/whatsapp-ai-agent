    # ============================================================
    # WARMUP - LOAD ALL RESOURCES AT STARTUP ONCE
    # ============================================================

    def warmup(self, include_heavy: bool = True) -> None:
        """
        Pre-load all resources at startup to avoid loading during queries.
        
        CRITICAL FIX: This loads ALL models ONCE at startup.
        After this, NO model loading happens during user queries.
        """
        if self._warmed_up:
            logger.info("✅ Resources already warmed up")
            return
        
        logger.info("🚀 Warming up AI resources at startup...")
        self._warmup_start_time = time.perf_counter()
        
        # Load lightweight resources first
        resources = [
            self.get_regex,
            self.get_ftfy,
            self.get_unidecode,
            self.get_dateparser,
            self.get_expiringdict,
            self.get_jsonschema,
            self.get_sqlglot,
            self.get_ahocorasick,
            self.get_nltk,
            self.get_textblob,
            self.get_aiofiles,
            self.get_joblib,
        ]
        
        if include_heavy:
            # Load heavy resources (these take 2-3 seconds each)
            # BUT ONLY ONCE AT STARTUP - NOT PER QUERY
            resources.extend([
                self.get_embeddings,   # ~2-3 seconds - ONCE
                self.get_spacy,        # ~1-2 seconds - ONCE
                self.get_flashrank,    # ~1 second - ONCE
                self.get_semantic_router, # ~1 second - ONCE
                self.get_lingua,       # ~0.5 second - ONCE
            ])
        
        # Load all in parallel
        futures = []
        for resource in resources:
            futures.append(self._executor.submit(resource))
        
        # Wait for all to complete with timeout
        loaded_count = 0
        for future in futures:
            try:
                result = future.result(timeout=15)
                if result is not None:
                    loaded_count += 1
            except Exception as e:
                logger.warning(f"⚠️ Resource warmup failed: {e}")
        
        self._warmed_up = True
        self._warmup_end_time = time.perf_counter()
        duration = (self._warmup_end_time - self._warmup_start_time) * 1000
        
        logger.info(f"✅ AI resources warmed up in {duration:.2f}ms ({loaded_count} resources loaded)")
        logger.info(f"📊 Resources now cached and will NOT reload during queries")

    async def warmup_async(self, include_heavy: bool = True) -> None:
        """Async warmup for FastAPI startup"""
        import asyncio
        loop = asyncio.get_event_loop()
        await loop.run_in_executor(self._executor, self.warmup, include_heavy)

    def health(self) -> dict[str, Any]:
        """Get health status of all resources"""
        return {
            "initialized": sorted(self._resources.keys()),
            "available_count": len(self._resources),
            "errors": dict(self._errors),
            "load_times": dict(self._load_times),
            "warmed_up": self._warmed_up,
            "warmup_duration_ms": (
                (self._warmup_end_time - self._warmup_start_time) * 1000
                if self._warmup_start_time and self._warmup_end_time
                else 0
            ),
            "ready": self._initialized,
        }

    def is_available(self, resource_name: str) -> bool:
        """Check if a specific resource is available"""
        return resource_name in self._resources

    def get_resource_status(self, resource_name: str) -> Optional[ResourceHealth]:
        """Get status of a specific resource"""
        return self._resource_health.get(resource_name)

    def clear_cache(self) -> None:
        """Clear all cached resources (for testing only)"""
        with self._lock:
            self._resources.clear()
            self._errors.clear()
            self._load_times.clear()
            self._resource_health.clear()
            self._warmed_up = False
            logger.info("🔄 Cleared all resource caches")


